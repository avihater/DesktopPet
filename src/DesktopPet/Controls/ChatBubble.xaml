<UserControl x:Class="DesktopPet.Controls.ChatBubble"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="250" Height="Auto"
             Visibility="Collapsed">

    <UserControl.Resources>
        <DropShadowEffect x:Key="BubbleShadow" Color="#000000"
                          BlurRadius="10" ShadowDepth="3" Opacity="0.25"/>
    </UserControl.Resources>

    <StackPanel HorizontalAlignment="Center">
        <!-- Main bubble container -->
        <Border x:Name="BubbleBorder"
                Background="#F0F8FF"
                BorderBrush="#4A90D9"
                BorderThickness="2"
                CornerRadius="16"
                Padding="14,10"
                Effect="{StaticResource BubbleShadow}"
                RenderTransformOrigin="0.5,1.0">

            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="BubbleScale" ScaleX="0" ScaleY="0"/>
                </TransformGroup>
            </Border.RenderTransform>

            <StackPanel>
                <!-- Robot name header -->
                <TextBlock x:Name="NameLabel"
                           Text="小Q"
                           FontWeight="Bold"
                           FontSize="11"
                           Foreground="#4A90D9"
                           Margin="0,0,0,4"/>

                <!-- Message text -->
                <TextBlock x:Name="MessageText"
                           Text=""
                           FontSize="13"
                           Foreground="#1A1A2E"
                           TextWrapping="Wrap"
                           MaxWidth="210"
                           LineHeight="20"/>

                <!-- Typing indicator -->
                <StackPanel x:Name="TypingIndicator"
                            Orientation="Horizontal"
                            Visibility="Collapsed"
                            Margin="0,6,0,0">
                    <Ellipse x:Name="Dot1" Width="6" Height="6" Fill="#4A90D9"
                             Margin="0,0,4,0" Opacity="0.3"/>
                    <Ellipse x:Name="Dot2" Width="6" Height="6" Fill="#4A90D9"
                             Margin="0,0,4,0" Opacity="0.3"/>
                    <Ellipse x:Name="Dot3" Width="6" Height="6" Fill="#4A90D9"
                             Opacity="0.3"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Arrow pointer -->
        <Polygon x:Name="BubbleArrow"
                 Points="0,0 12,0 6,8"
                 Fill="#F0F8FF"
                 Stroke="#4A90D9"
                 StrokeThickness="2"
                 HorizontalAlignment="Center"
                 Margin="0,-1,0,0"/>
    </StackPanel>

</UserControl>
