<UserControl x:Class="DesktopPet.Controls.PetRobot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="160" Height="220"
             Cursor="Hand">
    <UserControl.Resources>
        <!-- Robot color palette -->
        <SolidColorBrush x:Key="BodyMain" Color="#4A90D9"/>
        <SolidColorBrush x:Key="BodyDark" Color="#2C5F8A"/>
        <SolidColorBrush x:Key="BodyLight" Color="#7AB8F5"/>
        <SolidColorBrush x:Key="EyeWhite" Color="White"/>
        <SolidColorBrush x:Key="PupilColor" Color="#1A1A2E"/>
        <SolidColorBrush x:Key="AntennaGlow" Color="#00FF88"/>
        <SolidColorBrush x:Key="ChestScreen" Color="#0D1B2A"/>
        <SolidColorBrush x:Key="ChestLight" Color="#00FF88"/>
        <SolidColorBrush x:Key="MetalGray" Color="#8899AA"/>
    </UserControl.Resources>

    <!-- Root canvas for robot parts -->
    <Canvas x:Name="RobotCanvas" Width="160" Height="220">

        <!-- ===== Transform Groups for animations ===== -->
        <Canvas.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="BreathScale" 
                                CenterX="80" CenterY="180"
                                ScaleX="1.0" ScaleY="1.0"/>
            </TransformGroup>
        </Canvas.RenderTransform>

        <!-- ===== ANTENNA ===== -->
        <!-- Antenna stick -->
        <Line x:Name="AntennaStick"
              X1="80" Y1="58" X2="80" Y2="30"
              Stroke="{StaticResource MetalGray}"
              StrokeThickness="3"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round"
              RenderTransformOrigin="0.5,1.0">
            <Line.RenderTransform>
                <RotateTransform x:Name="AntennaSway" Angle="0" CenterX="80" CenterY="58"/>
            </Line.RenderTransform>
        </Line>

        <!-- Antenna ball (glowing) -->
        <Ellipse x:Name="AntennaBall"
                 Canvas.Left="72" Canvas.Top="22"
                 Width="16" Height="16"
                 Fill="{StaticResource AntennaGlow}">
            <Ellipse.Effect>
                <DropShadowEffect Color="#00FF88" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
            </Ellipse.Effect>
            <!-- Pulse animation -->
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.6" To="1.0" Duration="0:0:1.5"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
        </Ellipse>

        <!-- ===== HEAD ===== -->
        <!-- Head main shape -->
        <Rectangle x:Name="Head"
                   Canvas.Left="30" Canvas.Top="50"
                   Width="100" Height="75"
                   RadiusX="20" RadiusY="20"
                   Fill="{StaticResource BodyMain}">
            <Rectangle.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="2" Opacity="0.3"/>
            </Rectangle.Effect>
        </Rectangle>

        <!-- Head highlight (top gradient effect) -->
        <Rectangle Canvas.Left="30" Canvas.Top="50"
                   Width="100" Height="30"
                   RadiusX="20" RadiusY="20"
                   Fill="{StaticResource BodyLight}" Opacity="0.4"/>

        <!-- ===== EYES ===== -->
        <!-- Left eye white -->
        <Ellipse x:Name="LeftEyeWhite"
                 Canvas.Left="48" Canvas.Top="67"
                 Width="28" Height="32"
                 Fill="{StaticResource EyeWhite}"/>

        <!-- Left pupil -->
        <Ellipse x:Name="LeftPupil"
                 Canvas.Left="58" Canvas.Top="77"
                 Width="12" Height="14"
                 Fill="{StaticResource PupilColor}"/>

        <!-- Left eye highlight -->
        <Ellipse Canvas.Left="62" Canvas.Top="79"
                 Width="5" Height="5"
                 Fill="White" Opacity="0.8"/>

        <!-- Right eye white -->
        <Ellipse x:Name="RightEyeWhite"
                 Canvas.Left="84" Canvas.Top="67"
                 Width="28" Height="32"
                 Fill="{StaticResource EyeWhite}"/>

        <!-- Right pupil -->
        <Ellipse x:Name="RightPupil"
                 Canvas.Left="92" Canvas.Top="77"
                 Width="12" Height="14"
                 Fill="{StaticResource PupilColor}"/>

        <!-- Right eye highlight -->
        <Ellipse Canvas.Left="96" Canvas.Top="79"
                 Width="5" Height="5"
                 Fill="White" Opacity="0.8"/>

        <!-- ===== MOUTH ===== -->
        <!-- Smiling mouth -->
        <Path x:Name="Mouth"
              Canvas.Left="65" Canvas.Top="98"
              Data="M 5,0 Q 15,12 25,0"
              Stroke="{StaticResource BodyDark}"
              StrokeThickness="2.5"
              StrokeStartLineCap="Round"
              StrokeEndLineCap="Round"
              Fill="Transparent"/>

        <!-- ===== BODY ===== -->
        <!-- Body main shape -->
        <Rectangle x:Name="Body"
                   Canvas.Left="35" Canvas.Top="125"
                   Width="90" Height="70"
                   RadiusX="12" RadiusY="12"
                   Fill="{StaticResource BodyMain}">
            <Rectangle.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="5" ShadowDepth="2" Opacity="0.3"/>
            </Rectangle.Effect>
        </Rectangle>

        <!-- Body highlight -->
        <Rectangle Canvas.Left="35" Canvas.Top="125"
                   Width="90" Height="25"
                   RadiusX="12" RadiusY="12"
                   Fill="{StaticResource BodyLight}" Opacity="0.35"/>

        <!-- ===== CHEST SCREEN ===== -->
        <!-- Screen background -->
        <Rectangle x:Name="ChestScreen"
                   Canvas.Left="55" Canvas.Top="140"
                   Width="50" Height="30"
                   RadiusX="5" RadiusY="5"
                   Fill="{StaticResource ChestScreen}"/>

        <!-- Screen grid line 1 -->
        <Line Canvas.Left="55" Canvas.Top="150"
              X1="0" Y1="0" X2="50" Y2="0"
              Stroke="{StaticResource ChestLight}" StrokeThickness="0.5" Opacity="0.3"/>

        <!-- Screen grid line 2 -->
        <Line Canvas.Left="55" Canvas.Top="160"
              X1="0" Y1="0" X2="50" Y2="0"
              Stroke="{StaticResource ChestLight}" StrokeThickness="0.5" Opacity="0.3"/>

        <!-- Screen status dot -->
        <Ellipse x:Name="StatusDot"
                 Canvas.Left="73" Canvas.Top="148"
                 Width="14" Height="14"
                 Fill="{StaticResource ChestLight}">
            <Ellipse.Effect>
                <DropShadowEffect Color="#00FF88" BlurRadius="4" ShadowDepth="0" Opacity="0.6"/>
            </Ellipse.Effect>
            <Ellipse.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0.5" To="1.0" Duration="0:0:2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Ellipse.Triggers>
        </Ellipse>

        <!-- ===== LEFT ARM ===== -->
        <Rectangle x:Name="LeftArm"
                   Canvas.Left="22" Canvas.Top="138"
                   Width="14" Height="38"
                   RadiusX="7" RadiusY="7"
                   Fill="{StaticResource BodyMain}"
                   RenderTransformOrigin="0.5,0.0">
            <Rectangle.RenderTransform>
                <RotateTransform x:Name="LeftArmSwing" Angle="0"/>
            </Rectangle.RenderTransform>
        </Rectangle>

        <!-- Left hand -->
        <Ellipse Canvas.Left="21" Canvas.Top="172"
                 Width="16" Height="16"
                 Fill="{StaticResource BodyDark}"/>

        <!-- ===== RIGHT ARM ===== -->
        <Rectangle x:Name="RightArm"
                   Canvas.Left="124" Canvas.Top="138"
                   Width="14" Height="38"
                   RadiusX="7" RadiusY="7"
                   Fill="{StaticResource BodyMain}"
                   RenderTransformOrigin="0.5,0.0">
            <Rectangle.RenderTransform>
                <RotateTransform x:Name="RightArmSwing" Angle="0"/>
            </Rectangle.RenderTransform>
        </Rectangle>

        <!-- Right hand -->
        <Ellipse Canvas.Left="123" Canvas.Top="172"
                 Width="16" Height="16"
                 Fill="{StaticResource BodyDark}"/>

        <!-- ===== EARS / SIDE PANELS ===== -->
        <!-- Left ear -->
        <Rectangle Canvas.Left="24" Canvas.Top="62"
                   Width="10" Height="22"
                   RadiusX="5" RadiusY="5"
                   Fill="{StaticResource BodyDark}"/>

        <!-- Right ear -->
        <Rectangle Canvas.Left="126" Canvas.Top="62"
                   Width="10" Height="22"
                   RadiusX="5" RadiusY="5"
                   Fill="{StaticResource BodyDark}"/>

        <!-- ===== FEET ===== -->
        <!-- Left foot -->
        <Ellipse Canvas.Left="42" Canvas.Top="192"
                 Width="28" Height="14"
                 Fill="{StaticResource BodyDark}"/>

        <!-- Right foot -->
        <Ellipse Canvas.Left="90" Canvas.Top="192"
                 Width="28" Height="14"
                 Fill="{StaticResource BodyDark}"/>

        <!-- ===== SHADOW ON GROUND ===== -->
        <Ellipse Canvas.Left="45" Canvas.Top="208"
                 Width="70" Height="8"
                 Fill="#20000000"/>

    </Canvas>
</UserControl>
