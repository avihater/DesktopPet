<Window x:Class="DesktopPet.Windows.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="和小Q聊天" Height="520" Width="420"
        MinWidth="320" MinHeight="380"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#F5F8FC"
        Icon="{x:Null}">

    <Window.Resources>
        <Style x:Key="UserBubbleStyle" TargetType="Border">
            <Setter Property="Background" Value="#4A90D9"/>
            <Setter Property="CornerRadius" Value="14,14,4,14"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="60,0,10,4"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="AssistantBubbleStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14,14,14,4"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="10,0,60,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="BorderBrush" Value="#E0E6ED"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Chat message list -->
        <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="0"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="MessagesList"
                          VirtualizingPanel.ScrollUnit="Pixel">
                <ItemsControl.Template>
                    <ControlTemplate TargetType="ItemsControl">
                        <StackPanel x:Name="MessageStackPanel"
                                    IsItemsHost="True"
                                    Orientation="Vertical"/>
                    </ControlTemplate>
                </ItemsControl.Template>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input area -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="#E0E6ED" BorderThickness="0,1,0,0"
                Margin="0,8,0,0" CornerRadius="10">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputTextBox"
                         Grid.Column="0"
                         MinHeight="36" MaxHeight="100"
                         Padding="8,6"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="13"
                         TextWrapping="Wrap"
                         AcceptsReturn="False"
                         VerticalContentAlignment="Center"
                         KeyDown="InputTextBox_KeyDown"
                         GotFocus="InputTextBox_GotFocus"
                         LostFocus="InputTextBox_LostFocus">
                    <TextBox.Tag>输入消息，按 Enter 发送...</TextBox.Tag>
                </TextBox>

                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Width="36" Height="36"
                        Margin="8,0,0,0"
                        Background="#4A90D9"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="SendButton_Click"
                        ToolTip="发送 (Enter)">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#4A90D9" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="➤" FontSize="16"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
