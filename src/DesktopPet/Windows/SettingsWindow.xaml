<Window x:Class="DesktopPet.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="小Q设置" Height="480" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F8FC">

    <Window.Resources>
        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#334455"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>

        <Style x:Key="SettingDesc" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#8899AA"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SettingInput" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#D0D8E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16">
            <!-- Header -->
            <TextBlock Text="⚙ 小Q 助手设置"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#4A90D9" Margin="0,0,0,16"/>

            <!-- ===== AI Settings ===== -->
            <TextBlock Text="🤖 AI 设置" FontSize="15" FontWeight="Bold"
                       Foreground="#2C5F8A" Margin="0,8,0,4"/>

            <TextBlock Text="API Key" Style="{StaticResource SettingLabel}"/>
            <TextBlock Text="DeepSeek API Key（从 platform.deepseek.com 获取）"
                       Style="{StaticResource SettingDesc}"/>
            <PasswordBox x:Name="ApiKeyBox"
                         FontSize="13" Padding="8,6"
                         BorderBrush="#D0D8E0" BorderThickness="1"
                         Background="White"/>

            <TextBlock Text="API 地址" Style="{StaticResource SettingLabel}"/>
            <TextBox x:Name="ApiBaseUrlBox" Text="https://api.deepseek.com"
                     Style="{StaticResource SettingInput}"/>

            <TextBlock Text="模型名称" Style="{StaticResource SettingLabel}"/>
            <TextBox x:Name="ModelNameBox" Text="deepseek-chat"
                     Style="{StaticResource SettingInput}"/>

            <TextBlock Text="温度 (0-2)" Style="{StaticResource SettingLabel}"/>
            <TextBlock Text="越高回复越有创意，越低回复越确定"
                       Style="{StaticResource SettingDesc}"/>
            <Slider x:Name="TemperatureSlider"
                    Minimum="0" Maximum="2"
                    Value="0.7"
                    TickFrequency="0.1" IsSnapToTickEnabled="True"/>
            <TextBlock x:Name="TemperatureLabel"
                       Text="0.7" FontSize="12"
                       Foreground="#4A90D9" HorizontalAlignment="Right"/>

            <!-- ===== Persona Settings ===== -->
            <TextBlock Text="🎭 角色设定" FontSize="15" FontWeight="Bold"
                       Foreground="#2C5F8A" Margin="0,20,0,4"/>

            <TextBlock Text="机器人名字" Style="{StaticResource SettingLabel}"/>
            <TextBox x:Name="RobotNameBox" Text="小Q"
                     Style="{StaticResource SettingInput}"/>

            <TextBlock Text="你的名字" Style="{StaticResource SettingLabel}"/>
            <TextBox x:Name="UserNameBox" Text="主人"
                     Style="{StaticResource SettingInput}"/>

            <TextBlock Text="个人简介（知识库）" Style="{StaticResource SettingLabel}"/>
            <TextBlock Text="让 AI 更了解你，例如：'主人是一名程序员，喜欢喝咖啡，养了一只猫'"
                       Style="{StaticResource SettingDesc}"/>
            <TextBox x:Name="UserProfileBox" Text=""
                     Style="{StaticResource SettingInput}"
                     MinHeight="60" TextWrapping="Wrap"
                     AcceptsReturn="True"/>

            <TextBlock Text="系统提示词（System Prompt）" Style="{StaticResource SettingLabel}"/>
            <TextBlock Text="使用 {user_profile} 占位符代表知识库内容"
                       Style="{StaticResource SettingDesc}"/>
            <TextBox x:Name="SystemPromptBox"
                     Style="{StaticResource SettingInput}"
                     MinHeight="80" TextWrapping="Wrap"
                     AcceptsReturn="True"/>

            <!-- ===== Buttons ===== -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,12">
                <Button x:Name="CancelButton"
                        Width="80" Height="34"
                        Background="#E8ECF0" Foreground="#334455"
                        BorderThickness="0"
                        Cursor="Hand" Margin="0,0,10,0"
                        Click="CancelButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#E8ECF0" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="取消" Foreground="#334455" FontSize="13"/>
                </Button>

                <Button x:Name="SaveButton"
                        Width="100" Height="34"
                        Background="#4A90D9" Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="SaveButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#4A90D9" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="保存设置" Foreground="White" FontSize="13"/>
                </Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
